                        МассивРолей                         =   Новый Массив;
                        Для Каждого стр                     Из  МассивСтрок Цикл
                            Если Найти(стр,"""B"",")        > 0 Тогда
                                КолвоБулево                 =   КолвоБулево +1;
                                ТекЗначение                 =   Булево(Число(СтрЗаменить(стр,"""B"",","")));
                                Если КолвоБулево            = 1 Тогда
                                    строка.Данные.Вставить("АутентификацияОС",ТекЗначение);
                                ИначеЕсли КолвоБулево       = 2 Тогда
                                    строка.Данные.Вставить("АутентификацияСтандартная",ТекЗначение);
                                ИначеЕсли КолвоБулево       = 3 Тогда
                                    строка.Данные.Вставить("ЗапрещеноИзменятьПароль",ТекЗначение);
                                ИначеЕсли КолвоБулево       = 4 Тогда
                                    строка.Данные.Вставить("ПарольИзменен",ТекЗначение);
                                ИначеЕсли КолвоБулево       = 5 Тогда
                                    строка.Данные.Вставить("ПарольУстановлен",ТекЗначение);
                                ИначеЕсли КолвоБулево       = 6 Тогда
                                    строка.Данные.Вставить("ПоказыватьВСпискеВыбора",ТекЗначение);
                                КонецЕсли;
                            ИначеЕсли Найти(стр,"""S"",")   > 0 Тогда
                                КолвоСтрок                  =   КолвоСтрок +1;
                                ТекЗначение                 =   Очистить(стр);
                                ТекЗначение                 =   СтрЗаменить(ТекЗначение,"""","");
                                Если КолвоСтрок             = 1 Тогда
                                    строка.Данные.Вставить("Имя",ТекЗначение);
                                ИначеЕсли КолвоСтрок        = 2 Тогда
                                    строка.Данные.Вставить("ПолноеИмя",ТекЗначение);
                                ИначеЕсли КолвоСтрок        = 3 Тогда
                                    строка.Данные.Вставить("ПользовательОС",ТекЗначение);
                                ИначеЕсли КолвоСтрок        = 4 Тогда
                                    строка.Данные.Вставить("РежимЗапуска",ТекЗначение);
                                КонецЕсли;
                            ИначеЕсли Найти(стр,"""#""")    > 0 Тогда
                                Если КолвоСсылок            Тогда
                                    строка.Данные.Вставить("Язык","Язык.Русский");
                                    КолвоСсылок             =   КолвоСсылок + 1;
                                Иначе
                                    УИДРоли                 =   ЗначениеИзСтрокиВнутр("{"+стр+"}");
                                    МассивРолей.Добавить(Строка(УИДРоли));
                                КонецЕсли;
                            КонецЕсли;
                        КонецЦикла;
                        строка.Данные.Вставить("Роли",МассивРолей);
                    ИначеЕсли строка.Событие                =   "Данные. Инициализация предопределенных данных" Тогда
                        строка.Данные                       =   Новый ТаблицаЗначений;
                        Если Найти(Значение,"{""Pattern""}")> 0 Тогда
                            Значение                        =   СтрЗаменить(Значение,Символы.ПС+"{""Pattern""}","Pattern");
                            Значение                        =   СтрЗаменить(Значение,"},","");
                            Значение                        =   СтрЗаменить(Значение,"}","");
                            Значение                        =   СтрЗаменить(Значение,Символы.ПС,"");
                        Иначе
                            строка.Данные                   =   Неопределено;
                            Продолжить;
                        КонецЕсли;
                        МассивСтрок                         =   РазложитьСтрокуВМассивПодстрок(Значение,"{",Истина);
                        КолвоСтолбцов                       =   0;
                        Счетчик                             =   0;
                        СтруктураКолонок                    =   Новый ТаблицаЗначений;
                        СтруктураКолонок.Колонки.Добавить("ИмяКолонки");
                        СтруктураКолонок.Колонки.Добавить("ИмяМетаданных");
                        СтруктураЗначений                   =   Новый ТаблицаЗначений;
                        СтруктураЗначений.Колонки.Добавить("ИмяКолонки");
                        СтруктураЗначений.Колонки.Добавить("Значение");
                        Для Каждого стр                     Из  МассивСтрок Цикл
                            Если КолвоСтолбцов = 0 И Найти(стр,"Pattern") = 0 Тогда
                                Продолжить;
                            ИначеЕсли Найти(стр,"Pattern")  > 0 Тогда
                                КолвоСтолбцов               =   КолвоСтолбцов +1;
                                ИмяМетаданных               =   Лев(стр,Найти(стр,""",Pattern"));
                                ИмяМетаданных               =   СтрЗаменить(ИмяМетаданных,"""","");
                                ИмяКолонки                  =   СтрЗаменить(ИмяМетаданных,".","");
                                ИмяМетаданных               =   СтрЗаменить(ИмяМетаданных,".Ссылка","");
                                НоваяКолонка                =   СтруктураКолонок.Добавить();
                                НоваяКолонка.ИмяКолонки     =   ИмяКолонки;
                                НоваяКолонка.ИмяМетаданных  =   ИмяМетаданных;
                                строка.Данные.Колонки.Добавить(ИмяКолонки);
                            Иначе
                                Счетчик                     =   Счетчик+1;
                                Если Счетчик                >   КолвоСтолбцов Тогда
                                    Счетчик                 =   1;
                                    СтрокаТЗ                =   строка.Данные.Добавить();
                                    НомерСтолбца            =   0;
                                    Пока НомерСтолбца       <   КолвоСтолбцов Цикл
                                        СтрокаТЗ[СтруктураЗначений[НомерСтолбца].ИмяКолонки] = СтруктураЗначений[НомерСтолбца].Значение;
                                        НомерСтолбца        =   НомерСтолбца +1;
                                    КонецЦикла;
                                    СтруктураЗначений.Очистить();
                                КонецЕсли;
                                НовоеЗначение               =   СтруктураЗначений.Добавить();
                                НовоеЗначение.ИмяКолонки    =   СтруктураКолонок[Счетчик-1].ИмяКолонки;
                                Если Найти(СтруктураКолонок[Счетчик-1].ИмяКолонки,"Ссылка")>0 и Найти(стр,"@")>0  Тогда
                                    МетаданныеДляСсылки     =   СтруктураКолонок[Счетчик-1].ИмяМетаданных;
                                    МенеджерОбъекта         =   МенеджерОбъектаПоПолномуИмени(МетаданныеДляСсылки);
                                    стр                     =   СтрЗаменить(стр,"""","");
                                    УИДSQL                  =   Прав(стр,32);
                                    УИД1С                   =   Сред(УИДSQL, 25, 8) + "-" + Сред(УИДSQL, 21, 4) + "-" + Сред(УИДSQL, 17, 4) + "-" + Сред(УИДSQL, 1, 4) + "-" + Сред(УИДSQL, 5, 12);
                                    УИД1С                   =   Новый УникальныйИдентификатор(УИД1С);
                                    Попытка
                                        СсылкаНаДокумент    =   МенеджерОбъекта.ПолучитьСсылку(УИД1С);
                                    Исключение
                                        СсылкаНаДокумент    =   Строка(УИД1С);
                                    КонецПопытки;
                                    Значение                =   СсылкаНаДокумент;
                                ИначеЕсли Найти(стр, """L""")>0 Тогда
                                    Значение                =   "";
                                Иначе
                                    Значение                =   Очистить(стр);
                                    Значение                =   стрЗаменить(Значение,"""","");
                                КонецЕсли;
                                НовоеЗначение.Значение      =   Значение;
                            КонецЕсли;
                        КонецЦикла;
                        Если Счетчик                        > 0 Тогда
                            СтрокаТЗ                        =   строка.Данные.Добавить();
                            НомерСтолбца                    =   0;
                            Пока НомерСтолбца               <   КолвоСтолбцов Цикл
                                СтрокаТЗ[СтруктураЗначений[НомерСтолбца].ИмяКолонки] = СтруктураЗначений[НомерСтолбца].Значение;
                                НомерСтолбца                =   НомерСтолбца +1;
                            КонецЦикла;
                        КонецЕсли;
                    ИначеЕсли строка.Событие                =   "Информационная база. Обновление предопределенных данных" Тогда
                        Если СтрНайти(Значение,"Pattern") > 0 Тогда
                            строка.Данные = Новый ТаблицаЗначений;
                            МассивКолонок = Новый Массив;
                            МассивЗначений = Новый Массив;
                            КоличествоСтрок = СтрЧислоСтрок(Значение);
                            Для НомСтроки = 1 По КоличествоСтрок Цикл
                                ТекущаяСтрока = СтрПолучитьСтроку(Значение,НомСтроки);
                                Если СтрНайти(ТекущаяСтрока,"Pattern")>0 Тогда
                                    ТекущаяСтрока = СтрПолучитьСтроку(Значение,НомСтроки-1);
                                    ТекущаяСтрока = СтрЗаменить(ТекущаяСтрока,"""","");
                                    ТекущаяСтрока = СтрЗаменить(ТекущаяСтрока,",","");
                                    ТекущаяСтрока = СтрЗаменить(ТекущаяСтрока,"{","");
                                    ТекущаяСтрока = СтрЗаменить(ТекущаяСтрока,"}","");
                                    МассивКолонок.Добавить(ТекущаяСтрока);
                                ИначеЕсли СтрНайти(ТекущаяСтрока,"{""S"",") Тогда
                                    ТекущаяСтрока = ЗначениеИзСтрокиВнутр(ТекущаяСтрока);
                                    МассивЗначений.Добавить(ТекущаяСтрока);
                                КонецЕсли;
                            КонецЦикла;
                            Для каждого Колонка из МассивКолонок Цикл
                                строка.Данные.Колонки.Добавить(Колонка);
                            КонецЦикла;
                            МаксимальныйИндекс = МассивКолонок.Количество()-1;
                            Индекс = 0;
                            Для каждого Знч из МассивЗначений Цикл
                                Если Индекс > МаксимальныйИндекс Тогда
                                    Индекс = 0;
                                КонецЕсли;
                                Если Индекс = 0 Тогда
                                    НоваяСтрокаТЧ = строка.Данные.Добавить();
                                    НоваяСтрокаТЧ[МассивКолонок[Индекс]] = Знч;
                                Иначе
                                    НоваяСтрокаТЧ[МассивКолонок[Индекс]] = Знч;
                                КонецЕсли;
                                Индекс = Индекс + 1;
                            КонецЦикла;
                        ИначеЕсли Значение = """U""" Тогда
                            строка.Данные = "";
                        Иначе
                            Попытка
                                строка.Данные = ЗначениеИзСтрокиВнутр(Значение);
                            Исключение
                                строка.Данные = Значение;
                            КонецПопытки;
                        КонецЕсли;
                    ИначеЕсли Лев(Значение,5)               =   "{""R""," Тогда
                        Значение                            =   Сред(Значение,2,СтрДлина(Значение)-2);  // снимаем внешние {}: Nikita присылает сырое {"R",...}
                        КодМетаданныхИУИД                   =   Прав(Значение,СтрДлина(Значение)-4);
                        УИДSQL                              =   Лев(Прав(Значение,32),32);
                        УИД1С                               =   Сред(УИДSQL, 25, 8) + "-" + Сред(УИДSQL, 21, 4) + "-" + Сред(УИДSQL, 17, 4) + "-" + Сред(УИДSQL, 1, 4) + "-" + Сред(УИДSQL, 5, 12);
                        УИД1С                               =   Новый УникальныйИдентификатор(УИД1С);
                        МенеджерОбъекта                     =   МенеджерОбъектаПоПолномуИмени(строка.Метаданные);
                        Если МенеджерОбъекта                =   Неопределено Тогда
                            строка.данные                   =   "<Объект не найден> ("+стрЗаменить(Значение,"""R"",","")+")";
                        Иначе
                            Попытка
                                Если Найти(Строка(МенеджерОбъекта),"РегистрНакопления")>0 Или Найти(Строка(МенеджерОбъекта),"РегистрСведений")>0 Тогда
                                    НаборЗаписей            =   МенеджерОбъекта.СоздатьНаборЗаписей();
                                    МассивРегистраторов     =   НаборЗаписей.Отбор.Регистратор.ТипЗначения.Типы();
                                    Если МассивРегистраторов.Количество() > 0 Тогда
                                        Для Каждого Регистратор Из МассивРегистраторов Цикл
                                            МДОбъект        =   Метаданные.НайтиПоТипу(Регистратор);
                                            Если МДОбъект <> Неопределено Тогда
                                                МенеджерРегистратора        =   МенеджерОбъектаПоПолномуИмени("Документ."+МДОбъект.Имя);
                                                Попытка
                                                    СсылкаНаДокумент        =   МенеджерРегистратора.ПолучитьСсылку(УИД1С);
                                                    Если Найти(Строка(СсылкаНаДокумент),"<Объект не найден>")>0 И Найти(Строка(СсылкаНаДокумент),КодМетаданныхИУИД)>0 Тогда
                                                        Прервать;
                                                    ИначеЕсли Найти(Строка(СсылкаНаДокумент),"<Объект не найден>")>0 Тогда
                                                        СсылкаНаДокумент    =   "<Объект не найден> ("+КодМетаданныхИУИД+")";
                                                        Продолжить;
                                                    Иначе
                                                        Прервать;
                                                    КонецЕсли;
                                                Исключение
                                                    СсылкаНаДокумент        =   "<Объект не найден> ("+КодМетаданныхИУИД+")";
                                                КонецПопытки;
                                            КонецЕсли;
                                        КонецЦикла;
                                    Иначе
                                        СсылкаНаДокумент    =   "<Объект не найден> ("+КодМетаданныхИУИД+")";
                                    КонецЕсли;
                                Иначе
                                    СсылкаНаДокумент        =   МенеджерОбъекта.ПолучитьСсылку(УИД1С);
                                КонецЕсли;
                            Исключение
                                СсылкаНаДокумент            =   "<Объект не найден> ("+КодМетаданныхИУИД+")";
                            КонецПопытки;
                            строка.Данные                   =   СсылкаНаДокумент;
                        КонецЕсли;
                    Иначе
                        // Скаляры ({"S"},{"U"},{"D"},{"B"},{"N"}) и свёрнутый Nikita-ом P ({"S","..."})
                        // десериализуем штатно. Что не распозналось — показываем сырьём, чтобы не терять данные.
                        Попытка
                            строка.Данные                   =   ЗначениеИзСтрокиВнутр(Значение);
                        Исключение
                            строка.Данные                   =   Значение;
                        КонецПопытки;
                    КонецЕсли;
                ИначеЕсли   Ключ="R13"                      Тогда
                    строка.ПредставлениеДанных              =   Значение;
                ИначеЕсли   Ключ="R14"                      Тогда
                    строка.РабочийСервер                    =   Значение;
                ИначеЕсли   Ключ="R15"                      Тогда
                    строка.ОсновнойIPПорт                   =   Число(Значение);
                ИначеЕсли   Ключ="R16"                      Тогда
                    строка.ВспомогательныйIPПорт            =   Число(Значение);
                ИначеЕсли   Ключ="R17"                      Тогда
                    строка.Сеанс                            =   Число(Значение);
                ИначеЕсли   Ключ="R18"                      Тогда
                    строка.РаздОснДанные                    =   Число(Значение);
                ИначеЕсли   Ключ="R19"                      Тогда
                    строка.РаздДопДанные                    =   Число(Значение);
                КонецЕсли;
            КонецЦикла;
        КонецЦикла;
    Иначе
        КолвоСобытий                                        =   0;
        Сообщить(ТелоОтвета);
    КонецЕсли;
    //Сообщить(Строка(ТекущаяДата())+" Обработал данные");
    Возврат псжТабл;
КонецФункции

Функция ПолучитьСобытиеИзменениеПараметровЖР(Событие,Значение)
	Если Событие = "УровеньСобытий" Тогда
		Если Значение = 1 Тогда
			Значение = "Информация, Предупреждение, Ошибка";	
		ИначеЕсли Значение = 0 Тогда
			Значение = "Примечание, Информация, Предупреждение, Ошибка";		
		КонецЕсли;	
	КонецЕсли;	
	
	Если Событие = "ПериодРазделения" Тогда
		Если Значение = 0 Тогда
			Значение = "Не разделять";	
		ИначеЕсли Значение = 1 Тогда
			Значение = "Год";	
		ИначеЕсли Значение = 3 Тогда
			Значение = "Месяц";
		ИначеЕсли Значение = 4 Тогда
			Значение = "Неделя";
		ИначеЕсли Значение = 5 Тогда
			Значение = "День";
		ИначеЕсли Значение = 6 Тогда
			Значение = "Час";
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат Значение;
КонецФункции	

Функция МенеджерОбъектаПоПолномуИмени(ПолноеИмя)
	Перем КлассОМ, ИмяОМ, Менеджер;
	
	ЧастиИмени = РазложитьСтрокуВМассивПодстрок(ПолноеИмя, ".");
	
	Если ЧастиИмени.Количество() >= 2 Тогда
		КлассОМ = ЧастиИмени[0];
		ИмяОМ  = ЧастиИмени[1];
	КонецЕсли;
	
	Если      ВРег(КлассОМ) = "ПЛАНОБМЕНА" Тогда
		Менеджер = ПланыОбмена;
		
	ИначеЕсли ВРег(КлассОМ) = "СПРАВОЧНИК" Тогда
		Менеджер = Справочники;
		
	ИначеЕсли ВРег(КлассОМ) = "ДОКУМЕНТ" Тогда
		Менеджер = Документы;
		
	ИначеЕсли ВРег(КлассОМ) = "ЖУРНАЛДОКУМЕНТОВ" Тогда
		Менеджер = ЖурналыДокументов;
		
	ИначеЕсли ВРег(КлассОМ) = "ПЕРЕЧИСЛЕНИЕ" Тогда
		Менеджер = Перечисления;
		
	ИначеЕсли ВРег(КлассОМ) = "ОТЧЕТ" Тогда
		Менеджер = Отчеты;
		
	ИначеЕсли ВРег(КлассОМ) = "ОБРАБОТКА" Тогда
		Менеджер = Обработки;
		
	ИначеЕсли ВРег(КлассОМ) = "ПЛАНВИДОВХАРАКТЕРИСТИК" Тогда
		Менеджер = ПланыВидовХарактеристик;
		
	ИначеЕсли ВРег(КлассОМ) = "ПЛАНСЧЕТОВ" Тогда
		Менеджер = ПланыСчетов;
		
	ИначеЕсли ВРег(КлассОМ) = "ПЛАНВИДОВРАСЧЕТА" Тогда
		Менеджер = ПланыВидовРасчета;
		
	ИначеЕсли ВРег(КлассОМ) = "РЕГИСТРСВЕДЕНИЙ" Тогда
		Менеджер = РегистрыСведений;
		
	ИначеЕсли ВРег(КлассОМ) = "РЕГИСТРНАКОПЛЕНИЯ" Тогда
		Менеджер = РегистрыНакопления;
		
	ИначеЕсли ВРег(КлассОМ) = "РЕГИСТРБУХГАЛТЕРИИ" Тогда
		Менеджер = РегистрыБухгалтерии;
		
	ИначеЕсли ВРег(КлассОМ) = "РЕГИСТРРАСЧЕТА" Тогда
		Если ЧастиИмени.Количество() = 2 Тогда
			// Регистр расчета
			Менеджер = РегистрыРасчета;
		Иначе
			КлассПодчиненногоОМ = ЧастиИмени[2];
			ИмяПодчиненногоОМ = ЧастиИмени[3];
			Если ВРег(КлассПодчиненногоОМ) = "ПЕРЕРАСЧЕТ" Тогда
				// Перерасчет
				Попытка
					Менеджер = РегистрыРасчета[ИмяОМ].Перерасчеты;
					ИмяОм = ИмяПодчиненногоОМ;
				Исключение
					Менеджер = Неопределено;
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ВРег(КлассОМ) = "БИзНЕСПРОЦЕСС" Тогда
		Менеджер = БИзнесПроцессы;
		
	ИначеЕсли ВРег(КлассОМ) = "ЗАДАЧА" Тогда
		Менеджер = Задачи;
		
	ИначеЕсли ВРег(КлассОМ) = "КОНСТАНТА" Тогда
		Менеджер = Константы;
		
	ИначеЕсли ВРег(КлассОМ) = "ПОСЛЕДОВАТЕЛЬНОСТЬ" Тогда
		Менеджер = Последовательности;
	КонецЕсли;
	
	Если Менеджер <> Неопределено Тогда
		Попытка
			Возврат Менеджер[ИмяОМ];
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;
	
КонецФункции

Функция РазложитьСтрокуВМассивПодстрок(Знач Строка, Знач Разделитель = ",", Знач ПропускатьПустыеСтроки = Неопределено)
	
	Результат = Новый Массив;
	
	// для обеспечения обратной совместимости
	Если ПропускатьПустыеСтроки = Неопределено Тогда
		ПропускатьПустыеСтроки = ?(Разделитель = " ", Истина, Ложь);
		Если ПустаяСтрока(Строка) Тогда 
			Если Разделитель = " " Тогда
				Результат.Добавить("");
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	//
	
	Позиция = Найти(Строка, Разделитель);
	Пока Позиция > 0 Цикл
		Подстрока = Лев(Строка, Позиция - 1);
		Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Подстрока) Тогда
			Результат.Добавить(Подстрока);
		КонецЕсли;
		Строка = Сред(Строка, Позиция + СтрДлина(Разделитель));
		Позиция = Найти(Строка, Разделитель);
	КонецЦикла;
	
	Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Строка) Тогда
		Результат.Добавить(Строка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции   

Функция ПолучитьДатуИзСтроки(Стр) 
	Д = Дата("00010101000000");
	Если ПустаяСтрока(Стр) Тогда
		Возврат Д;
	КонецЕсли;
	Если Найти(Стр,".") > 0 Тогда
		Если Найти(Стр,":") > 0 И Найти(Стр," ") > 0 Тогда 
			М = РазложитьСтрокуВМассивПодстрок(Стр," ");
			Возврат ПолучитьДатуИзСтроки(М[0]);
		КонецЕсли;
		М = РазложитьСтрокуВМассивПодстрок(Стр,".");
	ИначеЕсли Найти(Стр,"/")>0 Тогда
		М = РазложитьСтрокуВМассивПодстрок(Стр,"/");
	ИначеЕсли Найти(Стр,",")>0 Тогда
		М = РазложитьСтрокуВМассивПодстрок(Стр,",");
	ИначеЕсли Найти(Стр,"-")>0 Тогда
		М = РазложитьСтрокуВМассивПодстрок(Стр,"-");
	КонецЕсли; 
	Попытка
		Если М.Количество() = 3 Тогда //"01.02.13" Или "01.02.2013"
			Год = ?(СтрДлина(М[2]) = 2,2000 + М[2],М[2]);
			Д = Дата(Год,М[1],М[0]);
		ИначеЕсли М.Количество() = 2 Тогда //"02.13" Или "02.2013";
			Год = ?(СтрДлина(М[1]) = 2,2000 + М[1],М[1]);
			Д = Дата(Год,М[0],1);
		КонецЕсли;
	Исключение
	КонецПопытки; 
	Возврат Д; 
КонецФункции   

Функция URLEncode4(str)
	
	
	СтрокаУТФ = ПреобразоватьСтрокуВУТФ8(str);
	МассивСимволов = UTF8(СтрокаУТФ);
	ret                                                     =    "";    
	//Для Каждого byte Из GetBinaryDataBufferFromString(string(str),TextEncoding.UTF8) Цикл
	Для Каждого byte Из МассивСимволов Цикл
		
		ret                                                    =    ret+"%"+toHex(byte);
	КонецЦикла;;
	//ret                                                        =    EncodeString(str,StringEncodingMethod.URLEncoding);
	Возврат ret;
КонецФункции   

Функция UTF8(Ст)
	Массив = Новый Массив;
	
	Для i=1 по СтрДлина(Ст) Цикл
		КодСимвола = КодСимвола(Ст,i);    
		Массив.Добавить(КодСимвола);
	КонецЦикла;
	Возврат Массив;
КонецФункции

Функция toHex(num)
	Пока num >    0 Цикл
		ret                                                    =    mid("0123456789ABCDEF" , num - 16*(int(num/16))+1,1) + ret;
		num                                                 =    ?(int(num/16)=0,0,num/16)
	КонецЦикла;;
	Возврат ?(StrLen(ret)-int(StrLen(ret)/2)*2,"0"+ret,ret);
КонецФункции

Функция ПреобразоватьСтрокуВУТФ8(Стр) Экспорт
	Длина=СтрДлина(Стр);
	Итог="";
	Для Н=1 По Длина Цикл
		Знак=Сред(Стр,Н,1);
		Код=КодСимвола(Знак);
		Если Код<128 Тогда
			Итог=Итог+Знак;
		Иначе
			Если (Код>=КодСимвола("А"))И(Код<=КодСимвола("п")) Тогда
				Итог=Итог+Символ(208)+Символ(144+Код-КодСимвола("А"));
			ИначеЕсли (Код>=КодСимвола("р"))И(Код<=КодСимвола("я")) Тогда
				Итог=Итог+Символ(209)+Символ(128+Код-КодСимвола("р"));
			ИначеЕсли (Знак="ё") Тогда
				Итог=Итог+Символ(209)+Символ(145);
			ИначеЕсли (Знак="Ё") Тогда
				Итог=Итог+Символ(208)+Символ(129);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат Итог;
КонецФункции

Функция Очистить(ОИмя)
	зпт                                                        =    Найти(ОИмя,",")+2;
	скб                                                        =    НайтиСимволСКонца(ОИмя,"}")-1;
	возврат Сред(ОИмя,зпт,скб-зпт);
КонецФункции    

Функция НайтиСимволСКонца(Знач Строка, Знач Символ) Экспорт
	
	Для Позиция = -СтрДлина(Строка) По -1 Цикл
		Если Сред(Строка, -Позиция, СтрДлина(Символ)) = Символ Тогда
			Возврат -Позиция;
		КонецЕсли;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

